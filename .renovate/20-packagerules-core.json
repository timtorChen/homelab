{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      // talos
      "groupName": "talos",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["talos/**", "kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["ghcr.io/siderolabs/installer"]
    },
    {
      // etcd
      "groupName": "etcd",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["talos/**", "kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["registry.k8s.io/etcd"]
    },
    {
      // kubernetes
      "groupName": "kubernetes",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["talos/**", "kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": [
        "registry.k8s.io/kube-apiserver",
        "registry.k8s.io/kube-controller-manager",
        "registry.k8s.io/kube-scheduler",
        "ghcr.io/siderolabs/kubelet"
      ]
    },
    {
      // coredns
      "groupName": "coredns",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["talos/**"],
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["registry.k8s.io/coredns/coredns"]
    },
    {
      // metrics-server - group
      "groupName": "metrics-server",
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["metrics-server"]
    },
    {
      // metrics-server - automerge
      "groupName": "metrics-server",
      "automerge": true,
      "matchUpdateTypes": ["major", "minor", "patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["metrics-server"]
    },
    {
      // gateway-api-crd - group
      "groupName": "gateway-api-crd",
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["gateway-api-crd"]
    },
    {
      // gateway-api-crd - automerge
      "groupName": "gateway-api-crd",
      "automerge": true,
      "matchUpdateTypes": ["patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["gateway-api-crd"]
    },
    {
      // snapshot-controller - group
      "groupName": "snapshot-controller",
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["snapshot-controller", "external-snapshotter-crd"]
    },
    {
      // snapshot-controller - automerge
      "groupName": "snapshot-controller",
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["github-tags"],
      "matchDepNames": ["snapshot-controller", "external-snapshotter-crd"]
    },
    {
      // cilium - group
      "groupName": "cilium",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["cilium"]
    },
    {
      // cilium - automerge
      "groupName": "cilium",
      "automerge": true,
      "matchUpdateTypes": ["patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["cilium"]
    },
    {
      // flux2 - group
      "groupName": "flux2",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["flux2"]
    },
    {
      // flux2 - automerge
      "groupName": "flux2",
      "automerge": true,
      "matchUpdateTypes": ["patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["flux2"]
    },
    {
      // cloudflared - group
      "groupName": "cloudflared",
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["docker.io/cloudflare/cloudflared"]
    },
    {
      // rook - group
      "groupName": "rook",
      "separateMultipleMinor": true,
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["rook-ceph"]
    },
    {
      // rook - automerge
      "groupName": "rook",
      "automerge": true,
      "matchUpdateTypes": ["patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["helm"],
      "matchDepNames": ["rook-ceph"]
    },
    {
      // ceph - group
      "groupName": "ceph",
      "semanticCommitScope": "core",
      "addLabels": ["area/core", "risk/high"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["quay.io/ceph/ceph"]
    },
    {
      // tuppr - group
      "groupName": "tuppr",
      "semanticCommitScope": "core",
      "addLabels": ["area/core"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["tuppr"]
    },
    {
      // tuppr - automerge
      "groupName": "tuppr",
      "automerge": true,
      "matchUpdateTypes": ["patch"],
      "matchFileNames": ["kubernetes/**"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["tuppr"]
    }
  ]
}
