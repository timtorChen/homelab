{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^talos/templates/.*\\.tmpl$"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+image:\\s+\\S+:(?<currentValue>v?[0-9]+\\.[0-9]+\\.[0-9]+)"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^kubernetes/system-upgrade/.*\\.yaml"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+version:\\s+(?<currentValue>v?[0-9]+\\.[0-9]+\\.[0-9]+)"
      ]
    }
  ]
}
